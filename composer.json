{
  "name": "djurovicigoor/postmark-bounced-email-blocker",
  "description": "This package will prevent sending an email to addresses that marked an email as bounced or spam in your postmark email stream.",
  "keywords": [
    "laravel",
    "mail",
    "email",
    "bounced",
    "spam",
    "postmark",
    "validator"
  ],
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Djurovic Igor",
      "email": "djurovic.igoor@gmail.com"
    }
  ],
  "minimum-stability": "dev",
  "prefer-stable": true,
  "autoload": {
    "psr-4": {
      "Djurovicigoor\\PostmarkBouncedEmailBlocker\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Djurovicigoor\\PostmarkBouncedEmailBlocker\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Djurovicigoor\\PostmarkBouncedEmailBlocker\\PostmarkBouncedEmailBlockerServiceProvider"
      ]
    }
  },
  "require": {
    "php": "^8.2",
    "illuminate/cache": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/config": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/console": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/contracts": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/support": "^10.0|^11.0|^12.0|^13.0",
    "illuminate/validation": "^10.0|^11.0|^12.0|^13.0"
  },
  "require-dev": {
    "laravel/pint": "^1.22",
    "mockery/mockery": "^1.4.2|^2.0",
    "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
    "phpunit/phpunit": "^10.5|^11.0|^12.0"
  },
  "scripts": {
    "format": "vendor/bin/pint",
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "sort-packages": true
  }
}
